#!/usr/bin/env bash
# pre-commit hook — enforce shared FeishuClient in claude-code/multi-file-refactor/
#
# Rejects commits that:
#   1. Hardcode `open.feishu.cn` (or its aliases) outside `common/feishu_client/`
#   2. DIY-call the Feishu token endpoints (bypassing feishu_client.auth)
#
# The check is scoped to claude-code/multi-file-refactor/ only; source-repo
# code elsewhere is untouched.

set -u

SCOPE_PREFIX="claude-code/multi-file-refactor/"
CLIENT_PATH="claude-code/multi-file-refactor/common/feishu_client/"

# Only look at added/modified files inside the scope.
# Use xargs-friendly newline output — mapfile is bash 4+, macOS ships 3.2.
STAGED=$(git diff --cached --name-only --diff-filter=AM | grep "^${SCOPE_PREFIX}" | grep -v "^${CLIENT_PATH}" || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

fail=0
while IFS= read -r file; do
    [ -z "$file" ] && continue
    # Skip binary + non-existent files (deletions already excluded by --diff-filter)
    if [ ! -f "$file" ]; then continue; fi
    case "$file" in
        *.py|*.md|*.sh|*.yaml|*.yml|*.json|*.toml) : ;;  # only scan text
        *) continue ;;
    esac

    # Ignore validation scripts and the hook itself
    case "$file" in
        *scripts/verify_feishu_parity.py) continue ;;
        *scripts/compare_*.py) continue ;;
        *scripts/old_sync_bitable.py|*scripts/old_crm_assistant.py) continue ;;
    esac

    # Look ONLY at newly added lines in the staged diff (starts with '+' but not '+++')
    diff_added=$(git diff --cached -U0 -- "$file" | grep -E '^\+' | grep -Ev '^\+\+\+')

    if echo "$diff_added" | grep -qE 'open\.feishu\.cn/open-apis/' ; then
        printf "${RED}[BLOCKED]${NC} %s\n" "$file"
        printf "  ${YELLOW}Hardcoded Feishu API URL detected.${NC}\n"
        printf "  Use ${YELLOW}feishu_client${NC} (accepts an ${YELLOW}endpoint=${NC} parameter). Only literal defaults\n"
        printf "  (e.g. ${YELLOW}endpoint=\"https://open.feishu.cn\"${NC} or an ${YELLOW}os.environ.get(...)${NC} fallback)\n"
        printf "  are allowed — do not concatenate the host with an ${YELLOW}/open-apis/${NC} path.\n"
        echo "$diff_added" | grep -nE 'open\.feishu\.cn/open-apis/' | sed 's/^/  > /'
        fail=1
    fi

    if echo "$diff_added" | grep -qE '/open-apis/auth/v3/tenant_access_token/internal|/open-apis/authen/v1/(access_token|refresh_access_token)' ; then
        printf "${RED}[BLOCKED]${NC} %s\n" "$file"
        printf "  ${YELLOW}Direct call to Feishu token endpoint detected.${NC}\n"
        printf "  Use ${YELLOW}feishu_client.get_tenant_access_token()${NC} / ${YELLOW}exchange_user_code()${NC} /\n"
        printf "  ${YELLOW}refresh_user_token()${NC} instead of hitting the auth endpoints yourself.\n"
        echo "$diff_added" | grep -nE '/open-apis/auth/v3/tenant_access_token/internal|/open-apis/authen/v1/(access_token|refresh_access_token)' | sed 's/^/  > /'
        fail=1
    fi
done <<< "$STAGED"

if [ $fail -ne 0 ]; then
    printf "\n${RED}Commit rejected.${NC} Route Feishu traffic through ${YELLOW}common/feishu_client/${NC}.\n"
    printf "To skip in an emergency: ${YELLOW}git commit --no-verify${NC} (discouraged).\n"
    exit 1
fi

exit 0
